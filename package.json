{
  "name": "claimshield",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "server"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:api": "npm run dev --prefix server",
    "dev:all": "concurrently -n web,api -c blue,green \"npm run dev\" \"npm run dev --prefix server\"",
    "dev:ai": "node ai-service/run.mjs",
    "dev:stack": "concurrently -n web,api,ai -c blue,green,magenta \"npm run dev\" \"npm run dev --prefix server\" \"node ai-service/run.mjs\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate"
  },
   "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.2.4",
    "ioredis": "^5.10.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6",
    "jspdf": "^2.5.2",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.2",
    "@tailwindcss/postcss": "^4",
    "@types/cookie": "^0.6.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
