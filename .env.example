# Database (docker-compose postgres on 5433)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/rate_limitter?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Next.js
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Express API
PORT=4000
JWT_SECRET="change-me-to-a-long-random-string"
AI_SERVICE_URL="http://127.0.0.1:5000"
UPLOAD_DIR="./server/uploads"

# Optional: OpenAI for extraction + explanations (falls back to heuristics)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Optional: Hugging Face Inference API when OpenAI is unset
HUGGINGFACE_API_TOKEN=""
HF_MODEL="meta-llama/Meta-Llama-3-8B-Instruct"

# Flask (reads same vars if run locally)
FLASK_DEBUG=1

# NextAuth (optional OAuth — existing app)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""
